{
  "name": "@ynh/cli",
  "version": "0.1.0",
  "description": "AI coding harness manager — npm integration for ynh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eyelock/ynh.git",
    "directory": "integrations/npm"
  },
  "bin": {
    "ynh": "./bin/ynh.js"
  },
  "main": "./index.js",
  "scripts": {
    "postinstall": "node install.js",
    "test": "node --test test/*.test.js",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "files": [
    "bin/",
    "lib/",
    "index.js",
    "install.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@ynh/cli-darwin-arm64": "0.1.0",
    "@ynh/cli-darwin-x64": "0.1.0",
    "@ynh/cli-linux-x64": "0.1.0",
    "@ynh/cli-linux-arm64": "0.1.0"
  }
}
